prefix=/e/data/openssl_1_1_1w/openssl_1_1_1w/dist_mingw
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: OpenSSL-libssl
Description: Secure Sockets Layer and cryptography libraries
Version: 1.1.1w
Requires.private: libcrypto
Libs: -L${libdir} -lssl
Cflags: -I${includedir}
